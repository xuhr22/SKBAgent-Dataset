+
+  @Before
+  public void setUp() throws Exception {
+    conf = HBaseConfiguration.create();
+    TEST_UTIL = new HBaseTestingUtility(conf);
+  }
+  
+  @After
+  public  void tearDown() throws Exception {
+    TEST_UTIL.shutdownMiniCluster();
